# App environment
ENV=development

# NVD API settings
NVD_API_URL=https://services.nvd.nist.gov
KEV_API_URL=https://www.cisa.gov/known-exploited-vulnerabilities
EPSS_API_URL=https://epss.example

# OpenCTI Connection Settings
OPENCTI_URL=http://localhost:8080
# Session cookie from browser to bypass Safeline WAF (e.g., sl-session=xyz...)
OPENCTI_COOKIE=
# OpenCTI API token (e.g., a2ccb376-800e-448e-8a32-4117c299dfb2)
OPENCTI_TOKEN=
# OpenCTI TAXII Collection ID (e.g., UUID format: 1a2b3c4d-5e6f-7a8b-9c0d-1e2f3a4b5c6d)
OPENCTI_TAXII_COLLECTION_ID=
# Optional Basic Authentication for TAXII
OPENCTI_USERNAME=
OPENCTI_PASSWORD=
